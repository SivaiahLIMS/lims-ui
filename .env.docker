# Docker Environment Variables for DEV Environment

# Environment
ENVIRONMENT=dev

# PostgreSQL Database Configuration (using Docker service name)
DB_URL=jdbc:postgresql://postgres:5432/lims
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=dev-jwt-secret-key-change-in-production-2024
JWT_EXPIRATION=86400000

# Frontend API URL (for Docker internal network)
VITE_API_URL=http://backend:8080